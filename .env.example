# ================================================================
# AI Content Intelligence Platform — Environment Configuration
# ================================================================
# Copy this file to .env and fill in all values before running.
# NEVER commit .env to version control.
# ================================================================

# ----------------------------------------------------------------
# Server
# ----------------------------------------------------------------
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# ----------------------------------------------------------------
# Security Keys (generate with: openssl rand -base64 32)
# ----------------------------------------------------------------
APP_KEYS="key1_replace_me,key2_replace_me"
API_TOKEN_SALT=replace_with_random_32_char_string
ADMIN_JWT_SECRET=replace_with_random_32_char_string
TRANSFER_TOKEN_SALT=replace_with_random_32_char_string
JWT_SECRET=replace_with_random_32_char_string
REFRESH_TOKEN_SECRET=replace_with_random_32_char_string

# ----------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------
DATABASE_CLIENT=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_cms
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi_secret
DATABASE_SSL=false
# DATABASE_URL=postgresql://strapi:strapi_secret@localhost:5432/ai_cms
# Optional SSL certs
# DATABASE_SSL_KEY=
# DATABASE_SSL_CERT=
# DATABASE_SSL_CA=
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20
DATABASE_CONNECTION_TIMEOUT=60000
DATABASE_SCHEMA=public

# ----------------------------------------------------------------
# Redis
# ----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_TLS=false

# Cache TTLs (seconds)
CACHE_TTL_ARTICLE=900        # 15 minutes
CACHE_TTL_CATEGORY=3600      # 1 hour
CACHE_TTL_SEARCH=300         # 5 minutes
CACHE_TTL_RECS=3600          # 1 hour
CACHE_TTL_TRENDING=600       # 10 minutes
CACHE_TTL_ANALYTICS=300      # 5 minutes

# ----------------------------------------------------------------
# AI — Google Gemini
# ----------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_MAX_RETRIES=3
GEMINI_TIMEOUT_MS=30000
GEMINI_RATE_LIMIT_RPM=60        # Requests per minute
GEMINI_RATE_LIMIT_RPD=1000      # Requests per day

# AI generation limits per user
AI_RATE_LIMIT_PER_USER_PM=10    # Per minute
AI_RATE_LIMIT_PER_USER_PD=100   # Per day

# ----------------------------------------------------------------
# Email
# ----------------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM="AI CMS <noreply@aicms.com>"
EMAIL_REPLY_TO=support@aicms.com

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# SendGrid (alternative)
# SENDGRID_API_KEY=your_sendgrid_api_key

# Resend (alternative)
# RESEND_API_KEY=your_resend_api_key

# ----------------------------------------------------------------
# OAuth (optional)
# ----------------------------------------------------------------
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_CALLBACK_URL=http://localhost:1337/api/auth/google/callback

OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_CALLBACK_URL=http://localhost:1337/api/auth/github/callback

# ----------------------------------------------------------------
# File Upload
# ----------------------------------------------------------------
# Options: local | aws-s3 | cloudinary
UPLOAD_PROVIDER=local
MAX_FILE_SIZE_MB=10

# AWS S3 (if UPLOAD_PROVIDER=aws-s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=

# Cloudinary (if UPLOAD_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ----------------------------------------------------------------
# BullMQ
# ----------------------------------------------------------------
JOB_CONCURRENCY_AI=3
JOB_CONCURRENCY_EMBEDDING=2
JOB_CONCURRENCY_EMAIL=5
JOB_CONCURRENCY_ANALYTICS=1
JOB_MAX_RETRIES_AI=3
JOB_MAX_RETRIES_EMAIL=5
JOB_RETRY_DELAY_AI=1000         # ms, doubles on each retry
JOB_RETRY_DELAY_EMAIL=30000     # ms, fixed

# ----------------------------------------------------------------
# Observability
# ----------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_PATH=./logs/app.log
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# Sentry (optional)
# SENTRY_DSN=https://xxx@o0.ingest.sentry.io/0

# ----------------------------------------------------------------
# Rate Limiting
# ----------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000      # 1 minute
RATE_LIMIT_MAX_GLOBAL=200       # Global requests per window
RATE_LIMIT_MAX_AUTH=20          # Auth endpoint requests per window

# ----------------------------------------------------------------
# Analytics
# ----------------------------------------------------------------
ANALYTICS_CRON_ROLLUP=0 2 * * *       # Daily at 02:00
ANALYTICS_CRON_TRENDING=*/10 * * * *  # Every 10 minutes
TRENDING_DECAY_HOURS=24               # Hours before views decay

# ----------------------------------------------------------------
# Workflow
# ----------------------------------------------------------------
WORKFLOW_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ----------------------------------------------------------------
# Frontend (CORS)
# ----------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
