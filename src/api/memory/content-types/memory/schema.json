{
  "kind": "collectionType",
  "collectionName": "memories",
  "info": {
    "singularName": "memory",
    "pluralName": "memories",
    "displayName": "Memory",
    "description": "Long-term AI memory for users and workspaces"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "content": {
      "type": "text",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "user_preference",
        "workspace_context",
        "fact"
      ],
      "default": "fact"
    },
    "last_accessed": {
      "type": "datetime"
    },
    "workspace": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::workspace.workspace"
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
