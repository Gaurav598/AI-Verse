{
  "kind": "collectionType",
  "collectionName": "generated_outputs",
  "info": {
    "singularName": "generated-output",
    "pluralName": "generated-outputs",
    "displayName": "Generated Output",
    "description": "Outputs like images or scripts generated by tools"
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": ["image", "video_script", "code_snippet", "document"],
      "required": true
    },
    "content": { "type": "text" },
    "media_url": { "type": "string" },
    "metadata": { "type": "json" },
    "is_favorite": { "type": "boolean", "default": false },
    "tool_run": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::tool-run.tool-run"
    },
    "workspace": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::workspace.workspace"
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
